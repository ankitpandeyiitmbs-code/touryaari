# =====================================================
# Touryaari Travels — Environment Variables
# Copy this file to .env.local and fill in your values
# =====================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-secret-key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin credentials (change before deploying!)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-to-something-strong

# =====================================================
# Email (SMTP) — for booking confirmation emails
# Gmail: use App Password (not your login password)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# =====================================================
# WhatsApp
# Enter number with country code, no spaces or +
# e.g. 919876543210 for India +91 98765 43210
# =====================================================
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
